# Copy this file to the repo root as .env  (e.g. `cp infra/env/.env.example .env`),
# then fill in real values. Only this template is tracked — never commit a populated .env.

# =============================================================================
# Twilio — https://console.twilio.com
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# =============================================================================
# Deepgram — https://console.deepgram.com  ($200 free credit)
# =============================================================================
DEEPGRAM_API_KEY=your_deepgram_api_key

# =============================================================================
# Gemini (primary runtime LLM — see ADR-005) — https://aistudio.google.com/apikey
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# Groq (fallback LLM) — https://console.groq.com  (free tier)
# =============================================================================
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# ElevenLabs — https://elevenlabs.io  (10k chars/month free)
# =============================================================================
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key
# Pick a voice from https://elevenlabs.io/app/voice-library
# Brian (warm baritone): nPczCjzI2devNBz1zQrb
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# =============================================================================
# Supabase — https://supabase.com
# Create a project, then Settings > API to find URL + keys
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # server-only; bypasses RLS
SUPABASE_ANON_KEY=your_anon_key  # dashboard-only; read-limited by RLS
# Optional: direct Postgres URL for psql/migrations
SUPABASE_DB_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# =============================================================================
# Voice agent server
# =============================================================================
PORT=8000
LOG_LEVEL=INFO
BUSINESS_SLUG=acme-plumbing
PUBLIC_BASE_URL=https://voice-ai-receptionist.onrender.com  # Render production URL (or ngrok URL for local dev)

# =============================================================================
# Dashboard (these go in Vercel project env settings; .env.local for dev)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
